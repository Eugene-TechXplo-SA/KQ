{
  "name": "kings-and-queens",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "apps/jobs/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "npm run -w @kq/web dev",
    "dev:api": "npm run -w @kq/api dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.1.3"
  }
}
